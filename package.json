{
  "name": "mcp-mindfull-memory",
  "version": "0.1.0",
  "description": "MCP server that writes memory files with user approval before saving",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "memory",
    "claude",
    "model-context-protocol"
  ],
  "author": "CaffeLento",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/CaffeLento/mcp-mindfull-memory.git"
  },
  "homepage": "https://github.com/CaffeLento/mcp-mindfull-memory#readme",
  "bugs": {
    "url": "https://github.com/CaffeLento/mcp-mindfull-memory/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
